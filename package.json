{
  "name": "compliance-monitoring-system",
  "version": "1.0.0",
  "description": "企业级合规交易监控系统 - 制裁名单筛查与风险管控",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "seed": "node server/scripts/seed.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "pdfkit": "^0.13.0",
    "node-cron": "^3.0.2",
    "bull": "^4.11.5",
    "express-rate-limit": "^7.1.2",
    "helmet": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "ioredis": "^5.3.2",
    "axios": "^1.6.0",
    "moment": "^2.29.4",
    "csv-parser": "^3.0.0",
    "archiver": "^6.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "@faker-js/faker": "^8.2.0"
  }
}
